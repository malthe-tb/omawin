{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.39/schema.bar.json",
  "monitor": 0,
  "font_family": "CaskaydiaMono Nerd Font",
  "theme": {
    "palette": "Base16",
    "name": "TokyoNightDark",
    "accent": "Base0D"
  },
  "left_widgets": [
    {
      "Komorebi": {
        "workspaces": {
          "enable": true,
          "hide_empty_workspaces": false
        },
        "layout": {
          "enable": true
        },
        "focused_window": {
          "enable": true,
          "show_icon": false
        }
      }
    }
  ],
  "right_widgets": [
    {
      "Media": {
        "enable": true
      }
    },
    {
      "Cpu": {
        "enable": true,
        "label_prefix": "Icon",
        "data_refresh_interval": 2
      }
    },
    {
      "Memory": {
        "enable": true,
        "label_prefix": "Icon",
        "data_refresh_interval": 5
      }
    },
    {
      "Date": {
        "enable": true,
        "format": "DayDateMonthYear"
      }
    },
    {
      "Time": {
        "enable": true,
        "format": "TwentyFourHour"
      }
    },
    {
      "Battery": {
        "enable": true
      }
    }
  ]
}
